<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.nutrilens.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/scannerFragment"
        android:name="com.example.nutrilens.ui.scanner.ScannerFragment"
        android:label="Scanner"
        tools:layout="@layout/fragment_scanner" />

    <fragment
        android:id="@+id/analyticsFragment"
        android:name="com.example.nutrilens.ui.analytics.AnalyticsFragment"
        android:label="Analytics"
        tools:layout="@layout/fragment_analytics" />

    <fragment
        android:id="@+id/resultFragment"
        android:name="com.example.nutrilens.ui.result.ResultFragment"
        android:label="Result"
        tools:layout="@layout/fragment_result">
        <argument
            android:name="foodName"
            app:argType="string"
            android:defaultValue="" />
        <argument
            android:name="calories"
            app:argType="integer"
            android:defaultValue="0" />
        <argument
            android:name="sugar"
            app:argType="float"
            android:defaultValue="0.0" />
        <argument
            android:name="riskLevel"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

    <fragment
        android:id="@+id/manualInputFragment"
        android:name="com.example.nutrilens.ui.manualinput.ManualInputFragment"
        android:label="Manual Input"
        tools:layout="@layout/fragment_manual_input">
        <argument
            android:name="foodName"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

</navigation>
